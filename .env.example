# DB1 — Operational (Prisma) — listings, users, leads, auth, compliance
DATABASE_URL=

# Direct (non-pooled) URL used by Prisma migrations only. Same host as
# DATABASE_URL without "-pooler" in the subdomain. Prisma's migrate commands
# need an unpooled connection so pg_advisory_lock holds across calls.
DIRECT_DATABASE_URL=

# DB2 — VOW sold records (Neon, schema: sold) — REPLACE BEFORE RUNNING
# Provision via Vercel Marketplace → Neon. Single Neon instance; sold + analytics
# are separate schemas on the same connection, splittable later without rework.
SOLD_DATABASE_URL=

# DB3 — Pre-computed analytics (Neon, schema: analytics) — REPLACE BEFORE RUNNING
# Currently points to the same Neon instance as SOLD_DATABASE_URL.
ANALYTICS_DATABASE_URL=

# DB4 — ClickHouse prediction engine (deferred to Month 3)
# PREDICTION_DATABASE_URL=

# Redis cache (Upstash) — REPLACE BEFORE RUNNING
# Provision via Vercel Marketplace → Upstash Redis. The Marketplace integration
# auto-injects these specific names into every Vercel environment.
UPSTASH_REDIS_KV_REST_API_URL=
UPSTASH_REDIS_KV_REST_API_TOKEN=

# TREB AMPRE — IDX-scoped token (active listings only). Used by detect/route.ts.
TREB_API_TOKEN=
TREB_API_URL=

# TREB AMPRE — VOW-scoped token (VOW agreement #1848370). Required for sold/
# closed records. Used by /api/sync/sold and /api/sync/sold/test only.
VOW_TOKEN=

# Cron auth (Authorization: Bearer <value>) for all new routes
CRON_SECRET=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# SMS (Twilio) — STUB MODE while these are empty; src/lib/twilio.ts logs to console only
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_FROM_NUMBER=
AAMIR_PHONE=+16478399090

# Google Ads + GA4 — used by /rentals/ads + /rentals/thank-you for conversion tracking
NEXT_PUBLIC_GA4_ID=
# DEPRECATED 2026-04-28: native AW- conversion firing was swapped for a GA4
# generate_lead event imported into Google Ads via the GA4 ↔ Ads link.
# Google Ads new UI removed the manual gtag conversion path for new accounts.
# Revisit only if scale justifies native AW-. Safe to leave blank.
NEXT_PUBLIC_AW_CONVERSION_ID=
NEXT_PUBLIC_AW_CONVERSION_LABEL=

# Anti-spam
HONEYPOT_FIELD=company_website

# Resend — fallback sender + reply-to for the renter cheat-sheet email
RESEND_REPLY_TO=

# Cheat-sheet — disabled until PDF exists at /public/milton-rental-cheat-sheet.pdf
CHEATSHEET_ENABLED=false
CHEATSHEET_PDF_URL=https://www.miltonly.com/milton-rental-cheat-sheet.pdf

# Maps (Mapbox)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Auth (NextAuth)
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Realtor contact info
REALTOR_PHONE=
REALTOR_EMAIL=
REALTOR_NAME=

# Calendly
NEXT_PUBLIC_CALENDLY_URL=

# AI Chat (Crisp)
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# App
NEXT_PUBLIC_SITE_URL=https://miltonly.com
NEXT_PUBLIC_GA_ID=

# PDF Generation
PDF_SERVICE_KEY=
