// Test-scope tsconfig for Node scripts (spot-check, backfill, diagnostics)
// that import Next server-component modules via tsx. Shims `server-only` to
// a no-op so those modules load outside the Next bundler.
//
// This shim exists because the generator module is imported by both Next
// server components AND standalone Node scripts. When the generator moves
// to a dedicated server-action or API route (post Phase 4.1), this shim
// goes away.
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "server-only": ["./scripts/_shims/server-only.ts"]
    }
  },
  "include": ["scripts/**/*.ts", "src/**/*.ts", "src/**/*.tsx"]
}
