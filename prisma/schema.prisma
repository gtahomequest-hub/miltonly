generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id             String    @id @default(cuid())
  mlsNumber      String    @unique
  address        String
  streetSlug     String
  neighbourhood  String
  city           String    @default("Milton")
  price          Int
  bedrooms       Int
  bathrooms      Float
  parking        Int
  basement       Boolean
  sqft           Int?
  propertyType   String // detached|semi|townhouse|condo
  status         String // active|sold|rented|expired
  soldPrice      Int?
  soldDate       DateTime?
  daysOnMarket   Int?
  photos         String[]
  description    String?
  latitude       Float
  longitude      Float
  schoolZone     String?
  goWalkMinutes  Int?
  condoBuilding     String?
  maintenanceFee    Int?
  // Detail fields
  lotSize           String?
  lotDepth          Float?
  lotWidth          Float?
  garageType        String?
  heatSource        String?
  roof              String?
  foundation        String?
  construction      String?
  exteriorFeatures  String[]
  interiorFeatures  String[]
  fireplace         Boolean   @default(false)
  architecturalStyle String?
  approximateAge    String?
  taxAmount         Float?
  taxYear           Int?
  maintenanceFeeAmt Float?
  directionFaces    String?
  crossStreet       String?
  sewer             String?
  waterSource       String?
  virtualTourUrl    String?
  listOfficeName    String?
  totalRooms        Int?
  kitchens          Int?
  transactionType   String?   // For Sale|For Lease
  petsAllowed       String?   // Yes|No|Restricted
  rentIncludes      String[]  // ["Building Insurance","Parking","Heat"]
  laundryFeatures   String?   // Ensuite|Shared|None
  cooling           String?   // Central Air|Window|None
  heatType          String?   // Forced Air|Baseboard|Radiant
  furnished         String?   // Furnished|Unfurnished|Partially
  possessionDetails String?   // Immediate|30-59 Days|TBA
  minLeaseTerm      Int?      // months
  locker            String?   // Exclusive|Shared|None
  // Display permission flags (IDX/DDF compliance)
  permAdvertise     Boolean   @default(true)  // InternetEntireListingDisplayYN
  displayAddress    Boolean   @default(true)  // InternetAddressDisplayYN
  listedAt          DateTime
  syncedAt          DateTime  @default(now())
  streetName        String?
  updatedAt         DateTime  @updatedAt
  createdAt         DateTime  @default(now())

  @@index([streetSlug])
  @@index([syncedAt])
  @@index([neighbourhood])
  @@index([status])
  @@index([propertyType])
  @@index([price])
  @@index([transactionType])
}

model Lead {
  id              String    @id @default(cuid())
  firstName       String
  email           String
  phone           String?
  intent          String // buyer|seller|renter|investor
  score           String // hot|warm|cold
  scorePoints     Int       @default(0)
  hasAgent        Boolean?
  isAgent         Boolean?
  street          String?
  bedrooms        Int?
  bathrooms       Float?
  parking         Int?
  basement        Boolean?
  timeline        String?
  priceRangeMin   Int?
  priceRangeMax   Int?
  neighbourhoods  String[]
  propertyType    String?
  condoBuilding   String?
  savedListings   String[]
  comparisonsMade String[]
  source          String // hero|seller_tool|buyer_alert|investor_report|street_page|condo_page|comparison|popup|chat|partner
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmKeyword      String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastContactAt   DateTime?
  convertedAt     DateTime?
  cookieId        String?

  @@index([email])
  @@index([intent])
  @@index([score])
  @@index([createdAt])
}

model VisitorProfile {
  id                      String   @id @default(cuid())
  cookieId                String   @unique
  viewedListings          String[]
  savedListings           String[]
  pillsClicked            String[]
  comparisonsMade         String[]
  streetsPreviewed        String[]
  buildingsPreviewed      String[]
  priceRangeMin           Int?
  priceRangeMax           Int?
  preferredNeighbourhoods String[]
  propertyType            String?
  bedrooms                Int?
  intent                  String?
  viewCount               Int      @default(0)
  searchCount             Int      @default(0)
  timeOnSiteSeconds       Int      @default(0)
  lastVisit               DateTime
  firstVisit              DateTime @default(now())
  leadId                  String?
}

model StreetData {
  id              String   @id @default(cuid())
  streetName      String
  streetSlug      String   @unique
  neighbourhood   String
  avgSoldPrice    Int
  avgPricePerSqft Int?
  soldCount12mo   Int
  avgDaysOnMarket Int
  soldVsAskPct    Float
  priceChange3mo  Float
  priceChange6mo  Float
  priceChange1yr  Float
  activeListings  Int
  schoolZone      String?
  goWalkMinutes   Int?
  lastUpdated     DateTime

  @@index([neighbourhood])
}

model CondoBuilding {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  address           String
  neighbourhood     String
  yearBuilt         Int?
  totalUnits        Int?
  managementCo      String?
  amenities         String[]
  petFriendly       Boolean?
  latitude          Float
  longitude         Float
  goWalkMinutes     Int?
  avgSalePrice1bd   Int?
  avgSalePrice2bd   Int?
  avgSalePrice3bd   Int?
  avgRent1bd        Int?
  avgRent2bd        Int?
  avgRent3bd        Int?
  avgMaintenanceFee Int?
  ownerRatioPct     Float?
  avgCapRate        Float?
  priceGrowth1yr    Float?
  activeForSale     Int      @default(0)
  activeForRent     Int      @default(0)
  lastUpdated       DateTime

  @@index([neighbourhood])
}

model StreetContent {
  id              String    @id @default(cuid())
  streetSlug      String    @unique
  streetName      String
  neighbourhood   String?
  description     String    @db.Text
  rawAiOutput     String?   @db.Text
  status          String    @default("draft")
  needsReview     Boolean   @default(true)
  aiGenerated     Boolean   @default(true)
  publishedAt     DateTime?
  generatedAt     DateTime  @default(now())
  marketDataHash  String?
  attempts        Int       @default(0)
  reviewNotes     String?   @db.Text
  metaTitle       String?
  metaDescription String?
  faqJson         String?   @db.Text
  statsJson       String?   @db.Text
  // VIP Hub — streets with 5+ active listings
  isVipHub        Boolean   @default(false)
  vipHubAt        DateTime? // When it became a hub
  vipDescription  String?   @db.Text // 800+ word enhanced content
  vipFaqJson      String?   @db.Text // Deeper FAQs for hub pages
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model StreetQueue {
  id          String    @id @default(cuid())
  streetSlug  String    @unique
  streetName  String
  status      String    @default("pending")
  attempts    Int       @default(0)
  lastError   String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  updatedAt   DateTime  @updatedAt
}

model Partner {
  id      String  @id @default(cuid())
  name    String
  type    String // mortgage|lawyer|mover|contractor
  company String
  phone   String
  email   String
  website String?
  bio     String?
  active  Boolean @default(true)
}

model ExclusiveListing {
  id                String   @id @default(cuid())
  title             String
  address           String
  city              String
  price             Int
  priceType         String   @default("sale")
  bedsMin           Int
  bedsMax           Int      @default(0)
  baths             Int
  parking           Int      @default(0)
  propertyType      String
  status            String   @default("active")
  badge             String   @default("Exclusive")
  description       String   @db.Text
  photos            String[]
  slug              String   @unique
  sqft              Int?
  yearBuilt         Int?
  lotSize           String?
  maintenance       Int?
  taxes             Int?
  taxYear           Int?
  heating           String?
  cooling           String?
  basement          String?
  garage            String?
  exterior          String?
  locker            String?
  exposure          String?
  petFriendly       Boolean?
  interiorFeatures  String[]
  exteriorFeatures  String[]
  rooms             Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ComplianceLog {
  id            String   @id @default(cuid())
  checkDate     DateTime @default(now())
  aiCompliance  Boolean  // No PropTx records in any prompt
  dataRetrieval Boolean  // Only one MLS feed pull per 24 hours
  listingExpiry Boolean  // No listings retained past 60 days
  displayPerms  Boolean  // perm_adv and disp_addr enforced
  consentCheck  Boolean  // All leads have valid consent
  allPassed     Boolean
  details       String?  @db.Text // JSON with failure details
  createdAt     DateTime @default(now())

  @@index([checkDate])
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  firstName      String?
  phone          String?
  verifyCode     String?   // 6-digit email verification code
  verifyExpiry   DateTime? // Code expiry (15 minutes)
  verified       Boolean   @default(false)
  savedListings  String[]  // MLS numbers
  leadId         String?   // Link to Lead record
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastLoginAt    DateTime?
  savedSearches  SavedSearch[]

  // VOW bona-fide-interest acknowledgement (Phase 2.5 compliance).
  // Required under PROPTX VOW Datafeed Agreement §3.2 "Consumer" definition +
  // §6.3(k). Recorded when a signed-in user first attempts to view VOW data.
  // All four fields are captured together so the acknowledgement is audit-provable
  // (timestamp alone isn't enough; we need the literal text shown + IP + UA).
  vowAcknowledgedAt           DateTime?
  vowAcknowledgementText      String?   // @db.Text — the literal string the user saw
  vowAcknowledgementIp        String?
  vowAcknowledgementUserAgent String?

  @@index([email])
}

model SavedSearch {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  name            String   // "Detached in Willmott under $1M"
  // Filter criteria
  propertyType    String?  // detached|semi|townhouse|condo
  neighbourhood   String?
  streetSlug      String?
  priceMin        Int?
  priceMax        Int?
  bedsMin         Int?
  bathsMin        Int?
  transactionType String?  // For Sale|For Lease
  // Alert settings
  alertEnabled    Boolean  @default(true)
  alertFrequency  String   @default("daily") // daily|instant
  lastAlertAt     DateTime?
  lastMatchCount  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([alertEnabled])
}
