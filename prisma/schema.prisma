}

model ExclusiveListing {
  id               String   @id @default(cuid())
  title            String
  address          String
  city             String
  price            Int
  priceType        String   @default("sale")
  bedsMin          Int
  bedsMax          Int      @default(0)
  baths            Int
  parking          Int      @default(0)
  propertyType     String
  status           String   @default("active")
  badge            String   @default("Exclusive")
  description      String   @db.Text
  photos           String[]
  slug             String   @unique
  sqft             Int?
  yearBuilt        Int?
  lotSize          String?
  maintenance      Int?
  taxes            Int?
  taxYear          Int?
  heating          String?
  cooling          String?
  basement         String?
  garage           String?
  exterior         String?
  locker           String?
  exposure         String?
  petFriendly      Boolean?
  interiorFeatures String[]
  exteriorFeatures String[]
  rooms            Json?
  createdAt        DateTime @default(now())
