generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
  schemas   = ["public", "ads"]
}

model Listing {
  id                 String    @id @default(cuid())
  mlsNumber          String    @unique
  address            String
  streetSlug         String
  neighbourhood      String
  city               String    @default("Milton")
  price              Int
  bedrooms           Int
  bathrooms          Float
  parking            Int
  basement           Boolean
  sqft               Int?
  propertyType       String // detached|semi|townhouse|condo
  // Ownership-type axis (additive — populated by ingest from PropTx; null on
  // pre-sync rows). propertyType stays the existing geometry bucket; these add
  // the tenure dimension it can't express.
  propertySubType    String? // raw PropTx PropertySubType: Condo Apartment|Condo Townhouse|Detached|Semi-Detached|Att/Row/Townhouse|...
  parcelOfTiedLand   String? // PropTx ParcelOfTiedLand flag: Yes|No (the POTL signal)
  propertyTypeRaw    String? // raw PropTx PropertyType: "Residential Freehold" | "Residential Condo & Other" (top-level tenure)
  status             String // active|sold|rented|expired
  // Lease lifecycle state for status='rented' rows. NULL for sale-side records.
  // Values: active|leased|expired|terminated|cancelled|suspended|withdrawn
  // (PropTx 'Price Change' MlsStatus collapses to 'active' here; the
  // lastPriceChangeAt timestamp captures the price-change signal separately.)
  leaseStatus        String?
  // Set by ingest when MlsStatus = 'Price Change'. Captures the most recent
  // price-change event timestamp for market-signal tracking. NULL for listings
  // that haven't had a tracked price change.
  lastPriceChangeAt  DateTime?
  soldPrice          Int?
  soldDate           DateTime?
  daysOnMarket       Int?
  photos             String[]
  description        String?
  latitude           Float
  longitude          Float
  schoolZone         String?
  goWalkMinutes      Int?
  condoBuilding      String?
  maintenanceFee     Int?
  // Detail fields
  lotSize            String?
  lotDepth           Float?
  lotWidth           Float?
  garageType         String?
  heatSource         String?
  roof               String?
  foundation         String?
  construction       String?
  exteriorFeatures   String[]
  interiorFeatures   String[]
  fireplace          Boolean   @default(false)
  architecturalStyle String?
  approximateAge     String?
  taxAmount          Float?
  taxYear            Int?
  maintenanceFeeAmt  Float?
  directionFaces     String?
  crossStreet        String?
  sewer              String?
  waterSource        String?
  virtualTourUrl     String?
  listOfficeName     String?
  totalRooms         Int?
  kitchens           Int?
  transactionType    String? // For Sale|For Lease
  petsAllowed        String? // Yes|No|Restricted
  rentIncludes       String[] // ["Building Insurance","Parking","Heat"]
  laundryFeatures    String? // Ensuite|Shared|None
  cooling            String? // Central Air|Window|None
  heatType           String? // Forced Air|Baseboard|Radiant
  furnished          String? // Furnished|Unfurnished|Partially
  possessionDetails  String? // Immediate|30-59 Days|TBA
  minLeaseTerm       Int? // months
  locker             String? // Exclusive|Shared|None
  // Display permission flags (IDX/DDF compliance)
  permAdvertise      Boolean   @default(true) // InternetEntireListingDisplayYN
  displayAddress     Boolean   @default(true) // InternetAddressDisplayYN
  listedAt           DateTime
  syncedAt           DateTime  @default(now())
  streetName         String?
  updatedAt          DateTime  @updatedAt
  createdAt          DateTime  @default(now())

  @@index([streetSlug])
  @@index([syncedAt])
  @@index([neighbourhood])
  @@index([status])
  @@index([propertyType])
  @@index([price])
  @@index([transactionType])
  @@index([leaseStatus])
  @@schema("public")
}

model Lead {
  id                      String         @id @default(cuid())
  firstName               String
  email                   String?
  phone                   String?
  intent                  String // buyer|seller|renter|investor
  score                   String // hot|warm|cold
  scorePoints             Int            @default(0)
  hasAgent                Boolean?
  isAgent                 Boolean?
  street                  String?
  bedrooms                Int?
  bathrooms               Float?
  parking                 Int?
  basement                Boolean?
  timeline                String?
  // Buyer-side fields (sales variant). Renter leads keep these NULL.
  // preApproved: "yes" | "no". mlsNumber: the listing the lead was viewing.
  preApproved             String?
  mlsNumber               String?
  // Free-text message from the AamirTrustCard message capture flow.
  // NULL for every other lead path (ads, modal, top form, booking band).
  // Server-side sanitized (trim + max 1000 chars + null-byte stripped) at
  // /api/leads. Surfaced in realtor email and SMS when present.
  message                 String?
  // Lead-magnet flow fields (Commit 4j).
  //   yourHomeAddress  — home-valuation lead only. The address of the
  //     submitter's CURRENT home (i.e. the property they want valued).
  //     Different from `street`/`mlsNumber` (which point at the listing
  //     they were viewing when they triggered the lead).
  //   consentText      — CASL audit trail. Exact consent string the user
  //     saw on the page at submit time. Captured so the disclosure
  //     evidence is preserved even if the on-page copy is later edited.
  //   consentTimestamp — when the user ticked the consent checkbox.
  //   matchCriteria    — market-pulse-unlock only. JSON snapshot of the
  //     filter slice that generated the aggregate report shown to the
  //     submitter (propertyType, bedrooms, city, periodDays, match_basis).
  //     Useful for nurture personalization in follow-up emails.
  yourHomeAddress         String?
  consentText             String?
  consentTimestamp        DateTime?
  matchCriteria           Json?
  priceRangeMin           Int?
  priceRangeMax           Int?
  neighbourhoods          String[]
  propertyType            String?
  condoBuilding           String?
  savedListings           String[]
  comparisonsMade         String[]
  source                  String // hero|seller_tool|buyer_alert|investor_report|street_page|condo_page|comparison|popup|chat|partner
  // First-touch attribution — captured from the original ad click that
  // produced the user's first session. Preserved across navigation by
  // src/lib/attribution.ts (localStorage + cookie).
  utmSource               String?
  utmMedium               String?
  utmCampaign             String?
  utmKeyword              String?
  utmContent              String?
  gclid                   String?
  // Last-touch attribution — overwritten on each new ad click. Useful for
  // multi-touch analytics; first-touch is what Google Ads imports.
  utmSourceLast           String?
  utmMediumLast           String?
  utmCampaignLast         String?
  utmTermLast             String?
  utmContentLast          String?
  gclidLast               String?
  // Capture metadata for the first-touch session.
  firstVisitAt            DateTime?
  landingPage             String?
  referrer                String?
  userAgent               String?
  ip                      String?
  notes                   String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  lastContactAt           DateTime?
  convertedAt             DateTime?
  cookieId                String?
  // Lead admin UI fields (MOD-58)
  leadStatus              String?        @default("New") // New|Contacted|Qualified|Junk|Booked|Closed|Lost
  qualificationReason     String?
  firstPage               String?
  internalReferrer        String?
  isQualified             Boolean        @default(false)
  leadTemperatureAtSubmit String? // Hot|Warm|Cold
  // Activity log relation (MOD-58)
  activities              LeadActivity[]

  @@index([email])
  @@index([intent])
  @@index([score])
  @@index([gclid])
  // Admin UI filterable indexes (MOD-58)
  @@index([leadStatus, createdAt(sort: Desc)])
  @@index([isQualified, createdAt(sort: Desc)])
  @@index([source, createdAt(sort: Desc)])
  @@index([leadTemperatureAtSubmit, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([leadStatus, isQualified, createdAt(sort: Desc)])
  @@index([source, leadStatus, createdAt(sort: Desc)])
  @@schema("public")
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  type      String // form_submit | email_sent | page_view | call_logged | status_change | note | manual_action
  payload   Json
  createdAt DateTime @default(now())
  createdBy String? // null = system, "aamir" = manual

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@schema("public")
}

model VisitorProfile {
  id                      String   @id @default(cuid())
  cookieId                String   @unique
  viewedListings          String[]
  savedListings           String[]
  pillsClicked            String[]
  comparisonsMade         String[]
  streetsPreviewed        String[]
  buildingsPreviewed      String[]
  priceRangeMin           Int?
  priceRangeMax           Int?
  preferredNeighbourhoods String[]
  propertyType            String?
  bedrooms                Int?
  intent                  String?
  viewCount               Int      @default(0)
  searchCount             Int      @default(0)
  timeOnSiteSeconds       Int      @default(0)
  lastVisit               DateTime
  firstVisit              DateTime @default(now())
  leadId                  String?

  @@schema("public")
}

// ───── WS3 three-tier data model — neighbourhood / residential-street /
// condo-building entities + the ingest review queue. (commit: ws3 entity taxonomy)
//
// Decisions locked by Brain Claude 2026-05-28 (see docs/adr/0001-three-tier-architecture.md):
//   - Residential streets and condo buildings are DISTINCT primitives.
//   - Condo building natural key = (street_number, street_name); condo_corp_number
//     is dirty/non-unique so it is kept as an attribute array, not a key.
//   - Neighbourhood string is NOT 1:1 — rawStrings[] holds every TREB variant
//     (e.g. "1041 - NA Rural Nassagaweya" + "Nassagaweya") mapping to one entity.
//   - VIP = top-20%-or-tied per neighbourhood per pool by recency-weighted SOLD
//     (sale) count. Sticky once earned; currentRank refreshes each cycle.
//   - Lease-only condo buildings are entities (standard tier) but never VIP.
//   - kind (geographic) and profile (content depth) may diverge (e.g. Milton North
//     = urban kind, rural_hub profile).
//   - Coordinates / polygons are nullable; geocoding is parked (string assignment).
model Neighbourhood {
  id          String   @id @default(cuid())
  slug        String   @unique // canonical key, e.g. "nassagaweya"
  name        String // "Nassagaweya"
  rawStrings  String[] // every TREB string mapping here
  profile     String   @default("urban_hub") // urban_hub | rural_hub | standard_no_hub
  isHub       Boolean  @default(true) // false only for standard_no_hub (Derry Green)
  hasVipTier  Boolean  @default(true) // true=urban_hub, false=rural/standard
  kind        String   @default("urban") // urban | rural | industrial
  centroidLat Float? // nullable — string assignment now; geocoding parked
  centroidLng Float?
  polygon     Json? // GeoJSON — future enrichment, no migration needed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  residentialStreets ResidentialStreet[]
  condoBuildings     CondoBuilding[]

  @@index([profile])
  @@schema("public")
}

// Residential street entity. slug == existing street_slug so StreetContent /
// StreetGeneration keep resolving at /streets/[slug] (parallel join layer, no rename).
model ResidentialStreet {
  id                     String         @id @default(cuid())
  slug                   String         @unique // = street_slug (canonical)
  name                   String
  shortName              String?
  streetType             String?
  neighbourhoodId        String?
  neighbourhood          Neighbourhood? @relation(fields: [neighbourhoodId], references: [id])
  neighbourhoodAmbiguous Boolean        @default(false)
  soldCount12mo          Int            @default(0) // raw sale count, trailing 12mo
  recencyWeightedSold    Float          @default(0) // weighted sale score (drives VIP rank)
  isVip                  Boolean        @default(false) // STICKY once true
  vipEarnedAt            DateTime?
  currentRank            Int? // DYNAMIC, refreshes each cycle (WS5 prominence)
  crossStreets           String[]
  lastClassifiedAt       DateTime?
  // Surfacing gate (registry ingest, 2026-07): an entity is surfaced in hero
  // search / autocomplete / hub lists when it renders a real page — the shared
  // predicate is `recencyWeightedSold > 0 OR hasPublishedPage`. Pageless dormant
  // entities (0 sold, 0 listings) stay in the DB, unsurfaced, until a first sale
  // or listing flips this (auto-promotion). Set true when a page is published.
  hasPublishedPage       Boolean        @default(false)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([neighbourhoodId])
  @@index([isVip])
  @@index([hasPublishedPage])
  @@schema("public")
}

// Append-only review queue. resolveNeighbourhood() writes here when a raw TREB
// string matches no Neighbourhood.rawStrings; Brain Claude reviews and either
// extends an existing rawStrings[] or creates a new Neighbourhood. Never auto-create.
model UnmappedNeighbourhoodString {
  id        String   @id @default(cuid())
  rawString String   @unique
  source    String? // "vow-sync" | "backfill" | ...
  seenCount Int      @default(1)
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())
  resolved  Boolean  @default(false)

  @@index([resolved])
  @@schema("public")
}

// Step 5 (registry ingest, 2026-07) — fail-loud queue for street_slugs minted by
// vow-sync that canonicalizeResidential could NOT match to the Town registry and
// are NOT on the off-registry allowlist. Mirrors UnmappedNeighbourhoodString: we
// log + review rather than auto-create a page. A genuinely-new subdivision street
// gets added to the registry (clears the queue); a junk/unit leak gets dismissed.
model StreetSlugReview {
  streetSlug String   @id
  sampleName String // a raw MLS street_name that produced this slug
  seenCount  Int      @default(1)
  firstSeen  DateTime @default(now())
  lastSeen   DateTime @default(now())
  resolved   Boolean  @default(false)
  source     String? // "vow-sync" | ...

  @@index([resolved])
  @@schema("public")
}

// CondoBuilding — extended from the pre-WS3 (unused, 0-row) model into the condo
// entity primitive. Legacy display fields relaxed to optional: the entity backfill
// sources from sold records and has no coordinates (0% coverage; geocoding parked).
model CondoBuilding {
  id                String   @id @default(cuid())
  // Legacy display fields (relaxed to optional in WS3).
  name              String?
  slug              String   @unique
  address           String?
  neighbourhood     String? // legacy raw string; new code uses neighbourhoodId
  yearBuilt         Int?
  totalUnits        Int?
  managementCo      String?
  amenities         String[]
  petFriendly       Boolean?
  latitude          Float?
  longitude         Float?
  goWalkMinutes     Int?
  avgSalePrice1bd   Int?
  avgSalePrice2bd   Int?
  avgSalePrice3bd   Int?
  avgRent1bd        Int?
  avgRent2bd        Int?
  avgRent3bd        Int?
  avgMaintenanceFee Int?
  ownerRatioPct     Float?
  avgCapRate        Float?
  priceGrowth1yr    Float?
  activeForSale     Int      @default(0)
  activeForRent     Int      @default(0)
  lastUpdated       DateTime @default(now())

  // ── WS3 entity-taxonomy fields ──────────────────────────────────────
  buildingAddress        String? // "490 Gordon Krantz Ave" — natural key
  displayName            String? // populated = buildingAddress at backfill (no clean name source)
  streetNumber           String?
  streetName             String?
  streetSlug             String? // parent street for link-graph
  condoCorpNumbers       String[] // dirty/multi — attribute, not key
  legalStories           Int?
  neighbourhoodId        String?
  neighbourhoodEntity    Neighbourhood? @relation(fields: [neighbourhoodId], references: [id])
  neighbourhoodAmbiguous Boolean        @default(false)
  saleCount12mo          Int            @default(0) // sale trades, trailing 12mo
  leaseCount12mo         Int            @default(0) // lease trades, trailing 12mo (informational)
  recencyWeightedSold    Float          @default(0) // weighted SALE score (lease excluded — sale-only VIP)
  isVip                  Boolean        @default(false) // STICKY; lease-only buildings stay false
  vipEarnedAt            DateTime?
  currentRank            Int?
  lastClassifiedAt       DateTime?

  @@index([neighbourhood])
  @@index([neighbourhoodId])
  @@index([streetSlug])
  @@index([isVip])
  @@schema("public")
}

model StreetContent {
  id              String    @id @default(cuid())
  streetSlug      String    @unique
  streetName      String
  neighbourhood   String?
  description     String    @db.Text
  rawAiOutput     String?   @db.Text
  status          String    @default("draft")
  // Render template: "standard" (full generated 8-section page) or "minimal"
  // (registry ingest, 2026-07 — a deterministic honest layout for zero/low-sale
  // streets: schools, neighbourhood-level market context, nearby streets, live
  // listings, and a plain no-resales statement; NO LLM prose). Route branches on
  // this so the ~423 standard pages are untouched.
  template        String    @default("standard")
  needsReview     Boolean   @default(true)
  aiGenerated     Boolean   @default(true)
  publishedAt     DateTime?
  generatedAt     DateTime  @default(now())
  marketDataHash  String?
  attempts        Int       @default(0)
  reviewNotes     String?   @db.Text
  metaTitle       String?
  metaDescription String?
  faqJson         String?   @db.Text
  statsJson       String?   @db.Text
  // VIP Hub — streets with 5+ active listings
  isVipHub        Boolean   @default(false)
  vipHubAt        DateTime? // When it became a hub
  vipDescription  String?   @db.Text // 800+ word enhanced content
  vipFaqJson      String?   @db.Text // Deeper FAQs for hub pages
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@schema("public")
}

model StreetQueue {
  id          String    @id @default(cuid())
  streetSlug  String    @unique
  streetName  String
  status      String    @default("pending")
  attempts    Int       @default(0)
  lastError   String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@schema("public")
}

model Partner {
  id      String  @id @default(cuid())
  name    String
  type    String // mortgage|lawyer|mover|contractor
  company String
  phone   String
  email   String
  website String?
  bio     String?
  active  Boolean @default(true)

