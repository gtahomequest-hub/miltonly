model ComplianceLog {
  id            String   @id @default(cuid())
  checkDate     DateTime @default(now())
  aiCompliance  Boolean // No PropTx records in any prompt
  dataRetrieval Boolean // Only one MLS feed pull per 24 hours
  listingExpiry Boolean // No listings retained past 60 days
  displayPerms  Boolean // perm_adv and disp_addr enforced
  consentCheck  Boolean // All leads have valid consent
  allPassed     Boolean
  details       String?  @db.Text // JSON with failure details
  createdAt     DateTime @default(now())

  @@index([checkDate])
  @@schema("public")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  firstName     String?
  phone         String?
  verifyCode    String? // 6-digit email verification code
  verifyExpiry  DateTime? // Code expiry (15 minutes)
  verified      Boolean       @default(false)
  savedListings String[] // MLS numbers
  leadId        String? // Link to Lead record
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lastLoginAt   DateTime?
  savedSearches SavedSearch[]

  // VOW bona-fide-interest acknowledgement (Phase 2.5 compliance).
  // Required under PROPTX VOW Datafeed Agreement §3.2 "Consumer" definition +
  // §6.3(k). Recorded when a signed-in user first attempts to view VOW data.
  // All four fields are captured together so the acknowledgement is audit-provable
  // (timestamp alone isn't enough; we need the literal text shown + IP + UA).
  vowAcknowledgedAt           DateTime?
  vowAcknowledgementText      String? // @db.Text — the literal string the user saw
  vowAcknowledgementIp        String?
  vowAcknowledgementUserAgent String?

  @@index([email])
  @@schema("public")
}

model SavedSearch {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  name            String // "Detached in Willmott under $1M"
  // Filter criteria
  propertyType    String? // detached|semi|townhouse|condo
  neighbourhood   String?
  streetSlug      String?
  priceMin        Int?
  priceMax        Int?
  bedsMin         Int?
  bathsMin        Int?
  transactionType String? // For Sale|For Lease
  // Alert settings
  alertEnabled    Boolean   @default(true)
  alertFrequency  String    @default("daily") // daily|instant
  lastAlertAt     DateTime?
  lastMatchCount  Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([alertEnabled])
  @@schema("public")
}

// ───── Phase 4.1 — AI-generated street description persistence ──────────────
// One row per street. Written by the backfill (scripts/backfill-descriptions.ts)
// and the spot-check harness; read at render time by /streets/[slug]/page.tsx.
//
// `status` is load-bearing for resumability — the backfill claims a slug atomically
// by upserting status=generating, which prevents concurrent workers from
// double-generating the same street. Readers MUST check status === "succeeded"
// before consuming sectionsJson/faqJson.
//
// `inputHash` (sha256 of stringified StreetGeneratorInput, 64 hex chars) gates
// idempotency: a rerun for the same input skips unless the hash changes.
//
// Cost tracking stored as Decimal(10,4) — supports four-decimal-cent precision
// for per-call spend over thousands of generations.

enum GenerationStatus {
  pending
  generating
  succeeded
  failed

  @@schema("public")
}

model StreetGeneration {
  streetSlug   String           @id
  sectionsJson Json
  faqJson      Json
  inputHash    String
  status       GenerationStatus @default(succeeded)
  generatedAt  DateTime         @default(now())
  attemptCount Int
  wordCounts   Json
  // Sections-only word count (FAQ excluded). Matches validator's
  // total-word floor logic in getTotalWordFloor / TOTAL_WORD_FLOOR_*.
  totalWords   Int
  tokensIn     Int?
  tokensOut    Int?
  costUsd      Decimal?         @db.Decimal(10, 4)

  @@index([status])
  @@index([generatedAt])
  @@schema("public")
}

// Structured review rows for streets that exhausted the generator's 3-attempt
// retry loop (or hit a non-retryable failure like NoCentroidError or
// rate_limit_exhausted). Inspected by operators; retried after 24h cooldown
// or on explicit --slug re-run.
model StreetGenerationReview {
  streetSlug    String   @id
  violations    Json
  lastAttemptAt DateTime @default(now())
  lastInputHash String

  @@index([lastAttemptAt])
  @@schema("public")
}

// ───── WS5 — neighbourhood hub-tier content persistence (A1) ────────────────
// NEW models mirroring the StreetGeneration / StreetContent pair, keyed on
// neighbourhoodSlug instead of streetSlug. They do NOT overload the street pair
// (DEC-WS5 A1 persistence). The shared fail-closed queue stays StreetGeneration-
// Review unchanged, keyed `hub:<slug>` (see src/lib/ai/hub/hubFailClosed.ts).
//
// HubGeneration mirrors StreetGeneration field-for-field (status via the existing
// GenerationStatus enum). HubContent mirrors StreetContent's PUBLISHED-SURFACE
// fields; the street-tier VIP-hub quartet (isVipHub/vipHubAt/vipDescription/
// vipFaqJson) is intentionally omitted — rural is NO-VIP (locked) and that flag
// was superseded by the WS3 entity model (ADR 0001). The street-tier parent
// `neighbourhood` string is also dropped: a hub IS the neighbourhood.

model HubGeneration {
  neighbourhoodSlug String           @id
  sectionsJson      Json
  faqJson           Json
  inputHash         String
  status            GenerationStatus @default(succeeded)
  generatedAt       DateTime         @default(now())
  attemptCount      Int
  wordCounts        Json
  totalWords        Int
  tokensIn          Int?
  tokensOut         Int?
  costUsd           Decimal?         @db.Decimal(10, 4)

  @@index([status])
  @@index([generatedAt])
  @@schema("public")
}

model HubContent {
  id                String    @id @default(cuid())
  neighbourhoodSlug String    @unique
  neighbourhoodName String
  description       String    @db.Text
  rawAiOutput       String?   @db.Text
  status            String    @default("draft")
  needsReview       Boolean   @default(true)
  aiGenerated       Boolean   @default(true)
  publishedAt       DateTime?
  generatedAt       DateTime  @default(now())
  marketDataHash    String?
  attempts          Int       @default(0)
  reviewNotes       String?   @db.Text
  metaTitle         String?
  metaDescription   String?
  faqJson           String?   @db.Text
  statsJson         String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@schema("public")
}

// WS5 — condo-building-tier persistence (mirror of HubGeneration/HubContent,
// keyed by CondoBuilding.slug). CondoGeneration = telemetry + canonical
// sections; CondoContent = the published surface. Fail-closed: a failed
// generation never touches CondoContent (prior published row preserved).
model CondoGeneration {
  buildingSlug String           @id
  sectionsJson Json
  faqJson      Json
  inputHash    String
  status       GenerationStatus @default(succeeded)
  generatedAt  DateTime         @default(now())
  attemptCount Int
  wordCounts   Json
  totalWords   Int
  tokensIn     Int?
  tokensOut    Int?
  costUsd      Decimal?         @db.Decimal(10, 4)

  @@index([status])
  @@index([generatedAt])
  @@schema("public")
}

model CondoContent {
  id              String    @id @default(cuid())
  buildingSlug    String    @unique
  buildingName    String
  description     String    @db.Text
  rawAiOutput     String?   @db.Text
  status          String    @default("draft")
  needsReview     Boolean   @default(true)
  aiGenerated     Boolean   @default(true)
  publishedAt     DateTime?
  generatedAt     DateTime  @default(now())
  marketDataHash  String?
  attempts        Int       @default(0)
  reviewNotes     String?   @db.Text
  metaTitle       String?
  metaDescription String?
  faqJson         String?   @db.Text
  statsJson       String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@schema("public")
}

// ───── Facebook Ads lead infrastructure ───────────────────────────────────
// Isolated in the `ads` schema (DB1) — namespace-separated from public so
// FB-driven leads never collide with the existing Lead/LeadActivity tables.
// Joined cross-schema later for attribution analysis (street → ad → close).
//
// Backed by ads.leads created via raw SQL on Neon. The DB schema is the
// source of truth; this model maps fields with @map / @@map.

model AdsLead {
  id              String   @id @default(uuid()) @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  source          String
  campaign        String?
  utmSource       String?  @map("utm_source")
  utmMedium       String?  @map("utm_medium")
  utmCampaign     String?  @map("utm_campaign")
  utmContent      String?  @map("utm_content")
  fbclid          String?
  name            String?
  email           String?
  phone           String?
  intent          String?
  timeline        String?
  budget          String?
  bedrooms        String?
  neighbourhood   String?
  propertyAddress String?  @map("property_address")
  notes           String?
  status          String   @default("new")
  meta            Json     @default("{}")

  @@index([createdAt(sort: Desc)])
  @@index([campaign])
  @@index([status])
  @@index([email])
  @@index([phone])
  @@map("leads")
  @@schema("ads")
}

// ───── Organic Growth Loop piece 1 — SENSE (GSC-informed SEO queue) ─────────
// Filled weekly by /api/seo/sense (keyword classes + light coverage). Later
// pieces (admin approval tab, ACT enqueuer, digest) consume these tables;
// nothing here touches streetQueue or any generation path.

model SeoOpportunity {
  id          String   @id @default(cuid())
  query       String
  class       String // SEEN_NOT_CLICKED | STRIKING_DISTANCE | NO_PAGE_MATCH | THIN_ENTITY
  entityType  String   @default("none") // street | none
  entitySlug  String?
  targetPage  String? // page currently riding the query (path form)
  impressions Int
  clicks      Int
  position    Float
  // Metrics from the PREVIOUS sense run (shifted on upsert when a new run
  // refreshes the row) — the digest's week-over-week movers source. Chosen
  // over a per-run SeoMetricSnapshot table: no row explosion, one read.
  prevImpressions Int?
  prevClicks      Int?
  prevPosition    Float?
  status      String   @default("pending") // pending | approved | rejected | auto_queued | done
  senseRunId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([query, class])
  @@index([status])
  @@index([class])
  @@schema("public")
}

// Append-only audit trail for every automated SEO-loop action.
model SeoActionLog {
  id            String   @id @default(cuid())
  action        String
  opportunityId String?
  detail        Json     @default("{}")
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@schema("public")
}

model SenseRun {
  id                String    @id @default(cuid())
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?
  keywordRows       Int       @default(0)
  coverageInspected Int       @default(0)
  coverageMode      String    @default("light") // light | full
  indexedCount      Int?
  // Whole-property 90d totals across ALL queries (incl. winning/branded) —
  // the digest's headline numbers, so it never re-calls GSC.
  totalImpressions  Int?
  totalClicks       Int?
  error             String?

  @@index([startedAt])
  @@schema("public")
}

// Singleton resume-state for light-mode coverage inspection (serverless has
// no durable FS; this replaces the CLI audit script's local state.json).
model SeoCoverageState {
  id        String   @id
  stateJson Json
  updatedAt DateTime @updatedAt

  @@schema("public")
}
